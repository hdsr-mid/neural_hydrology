KNMI_API_URL=https://api.dataplatform.knmi.nl/open-data
KNMI_API_KEY=

# Optional: control rolling-ensemble composition (HARMONIE EPS batches)
# ENSEMBLE_STARTTIME is the oldest init time (UTC) in YYYYMMDDHH format (hour 1).
# The script will try to fetch 6 consecutive hourly runs starting at ENSEMBLE_STARTTIME
ENSEMBLE_STARTTIME=

# DOWNLOAD_ENSEMBLE controls how HARMONIE `.tar` files are obtained.
# - 1 (enabled): clears `neural_hydrology/data_ens/_tmp_harmonie/` first, then downloads the needed p2a/p2b `.tar` files
#   from KNMI Open Data again (no local cache reuse).
# - 0 (disabled): does NOT delete anything and will ONLY use local `.tar` files from `neural_hydrology/data_ens/_tmp_harmonie/`.
#   In this mode, `ENSEMBLE_STARTTIME` must be set and the expected files must already exist, otherwise the script fails.
DOWNLOAD_ENSEMBLE=
